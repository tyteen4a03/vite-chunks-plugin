{
  "entries": {
    "shared/app-a": {
      "styles": {
        "patterns": [
          "https://example\\.com/dist/css/shared\\.css",
          "https://example\\.com/dist/css/app-a\\.css"
        ]
      },
      "scripts": {
        "patterns": [
          "https://example\\.com/dist/js/shared-[A-Za-z0-9_-]+\\.js",
          "https://example\\.com/dist/js/shared/app-a\\.js"
        ]
      },
      "manifest": {
        "styles": ["/dist/css/shared.css", "/dist/css/app-a.css"],
        "scripts": ["/dist/js/shared/app-a.js"],
        "preloadsPattern": "^/dist/js/shared-[A-Za-z0-9_-]+\\.js$"
      }
    },
